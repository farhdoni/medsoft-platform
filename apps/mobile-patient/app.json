{
  "expo": {
    "name": "AIVITA",
    "slug": "aivita",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "aivita",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#9c5e6c"
    },
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "uz.aivita.app"
    },
    "android": {
      "package": "uz.aivita.app",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#c87d8a"
      },
      "permissions": ["INTERNET", "RECEIVE_BOOT_COMPLETED", "VIBRATE"]
    },
    "plugins": [
      "expo-camera",
      [
        "expo-notifications",
        {
          "icon": "./assets/icon.png",
          "color": "#c87d8a"
        }
      ],
      "expo-secure-store",
      "expo-local-authentication",
      "expo-image-picker"
    ],
    "extra": {
      "eas": {
        "projectId": "b634c834-d7c1-43d7-9cee-0d150d4136ce"
      }
    }
  }
}
