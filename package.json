{
  "name": "medsoft-platform",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "pnpm --parallel --filter './apps/*' dev",
    "build": "pnpm --filter './packages/*' build && pnpm --filter './apps/*' build",
    "lint": "pnpm --recursive lint",
    "typecheck": "pnpm --recursive typecheck"
  },
  "devDependencies": {
    "typescript": "^5.4.5"
  },
  "engines": {
    "node": ">=22",
    "pnpm": ">=9"
  },
  "pnpm": {
    "overrides": {
      "@types/react": "^19",
      "@types/react-dom": "^19"
    },
    "onlyBuiltDependencies": [
      "es5-ext",
      "esbuild",
      "sharp"
    ],
    "patchedDependencies": {
      "react-native-health-connect@3.5.3": "patches/react-native-health-connect@3.5.3.patch"
    }
  }
}
