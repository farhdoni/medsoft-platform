# ╔══════════════════════════════════════════════════════════════╗
# ║            AIVITA PLATFORM — Environment Variables           ║
# ║  Copy this file to .env (api) and apps/aivita/.env.local     ║
# ╚══════════════════════════════════════════════════════════════╝

# === Shared ===
NODE_ENV=development

# ─── Database ────────────────────────────────────────────────────
# apps/api + packages/db
DATABASE_URL=postgresql://aivita:password@localhost:5432/aivita

# ─── Redis ───────────────────────────────────────────────────────
# apps/api — sessions, queues
REDIS_URL=redis://localhost:6379

# ─── API Server (apps/api) ───────────────────────────────────────
API_PORT=4000
AIVITA_URL=https://aivita.uz
CORS_ORIGINS=https://aivita.uz,https://admin.aivita.uz,http://localhost:3001

# SESSION_SECRET — MUST be ≥ 32 chars, same value in both API and aivita frontend
# Generate: openssl rand -hex 32
SESSION_SECRET=replace_with_32_plus_char_random_secret_key_here_at_least_32c

# ─── JWT Keys (ES256) ─────────────────────────────────────────────
# Generate: openssl genpkey -algorithm EC -pkeyopt ec_paramgen_curve:P-256 | openssl pkcs8 -topk8 -nocrypt -outform PEM
# Then base64: base64 -w0 private.pem
JWT_PRIVATE_KEY_BASE64=base64_encoded_ec_private_key_pkcs8_pem
JWT_PUBLIC_KEY_BASE64=base64_encoded_ec_public_key_pem
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ─── Email / SMTP ─────────────────────────────────────────────────
# EMAIL_PROVIDER=mock  →  prints to console (dev)
# EMAIL_PROVIDER=smtp  →  sends real emails
EMAIL_PROVIDER=mock
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=noreply@aivita.uz
SMTP_PASSWORD=
SMTP_FROM_NAME=Aivita
SMTP_FROM_EMAIL=noreply@aivita.uz

# ─── Admin panel ──────────────────────────────────────────────────
ADMIN_URL=https://admin.aivita.uz
SEED_SUPERADMIN_EMAIL=admin@aivita.uz
SEED_SUPERADMIN_PASSWORD=change_me_on_first_login

# ─── AI (Anthropic Claude) ────────────────────────────────────────
# Required for AI chat, checkup, document parsing
# Get key: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...

# ─── SMS (Eskiz.uz) ───────────────────────────────────────────────
# Required for OTP verification via SMS
# Get token: https://cabinet.eskiz.uz/
ESKIZ_TOKEN=

# ─── Payment Providers ────────────────────────────────────────────
# Click — https://merchant.click.uz/
CLICK_MERCHANT_ID=
CLICK_SERVICE_ID=
CLICK_SECRET_KEY=

# Payme — https://merchant.payme.uz/
PAYME_MERCHANT_ID=
PAYME_SECRET_KEY=

# Uzum Bank — https://developer.uzumbank.uz/
UZUM_MERCHANT_ID=
UZUM_SECRET_KEY=
UZUM_API_URL=https://api.uzum.uz/payment

# ─── APK Download (optional) ──────────────────────────────────────
ANDROID_APK_URL=https://aivita.uz/app/aivita.apk

# ════════════════════════════════════════════════════════════════════
# === Frontend: apps/aivita/.env.local  ===
# ════════════════════════════════════════════════════════════════════

# URL of the API server (no trailing slash)
NEXT_PUBLIC_API_URL=https://api.aivita.uz

# Public URL of this Next.js app
NEXT_PUBLIC_APP_URL=https://aivita.uz

# SESSION_SECRET — MUST match the API's SESSION_SECRET exactly
SESSION_SECRET=replace_with_32_plus_char_random_secret_key_here_at_least_32c

# ════════════════════════════════════════════════════════════════════
# === Frontend: apps/admin/.env.local  ===
# ════════════════════════════════════════════════════════════════════

# NEXT_PUBLIC_API_URL=https://api.aivita.uz
